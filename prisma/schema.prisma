generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WorkoutDraft {
  id        String   @id @default(cuid())
  userId    String   @unique
  payload   Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainerMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  username       String?  @unique
  password       String
  image          String?
  coverImage     String?
  bodyweight     Float?
  birthDate      DateTime?
  sex            String?
  goals          String?
  preferredSplit String?
  timezone       String?
  bio            String?
  experienceLevel String?
  primaryFocus   String?
  trainingPhase  String?
  trainingDays   Int?
  injuries       String?
  coachPrompt    String?
  preferredWarmups Json?
  moveGoalKcal     Int?
  exerciseGoalMin  Int?
  notifyFriendWorkouts Boolean @default(true)
  weeklyAnalysisCache Json?
  height         Float?
  bodyFat        Float?
  restingHR      Int?
  waist          Float?
  hips           Float?
  chest          Float?
  shoulders      Float?
  neck           Float?
  arm            Float?
  forearm        Float?
  thigh          Float?
  calf           Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workouts        Workout[]
  prs             PersonalRecord[]
  goalList        Goal[]
  groupMembers    GroupMember[]
  comments        Comment[]
  reactions       Reaction[]
  trainerMessages TrainerMessage[]
  groupPosts      GroupPost[]
  postComments    PostComment[]
  postReactions   PostReaction[]
  challenges      Challenge[]           @relation("ChallengeCreator")
  challengeJoins  ChallengeParticipant[]
  workoutDraft    WorkoutDraft?
  customExercises Exercise[]            @relation("ExerciseOwner")
  passwordResetTokens PasswordResetToken[]
  healthAccount   HealthAccount?
  following       Follow[]              @relation("Following")
  followers       Follow[]              @relation("Followers")
  crewChallenges       CrewChallenge[]       @relation("CrewChallengeCreator")
  crewChallengeMembers CrewChallengeMember[]
  sentFriendRequests     FriendRequest[]    @relation("FriendRequestFrom")
  receivedFriendRequests FriendRequest[]    @relation("FriendRequestTo")
  ambientHeartRates      AmbientHeartRateSample[]
  pushSubscriptions      PushSubscription[]
  recoveryDays           RecoveryDay[]
  notifications          Notification[]        @relation("NotificationRecipient")
  notificationsActed     Notification[]        @relation("NotificationActor")
}

/// Persistent in-app notification (the inbox). Survives even when a Web Push
/// is missed or push was never enabled. Created e.g. when someone accepts your
/// crew request. `read` flips once the recipient opens /notifications.
model Notification {
  id        String   @id @default(cuid())
  userId    String   // recipient
  type      String   // FRIEND_ACCEPT (extensible)
  actorId   String?  // who triggered it (for avatar/name)
  body      String
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
}

/// One recovery score per user per local day, upserted on sync. Powers the
/// 7-day recovery trend on /recovery (the HealthAccount snapshot only holds the
/// latest).
model RecoveryDay {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String   // local YYYY-MM-DD
  score     Int
  band      String?
  sleepMin  Int?
  hrvMs     Float?
  restingHr Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, dateKey])
}

/// A Web Push subscription for a user's device/browser. One row per
/// device+browser (keyed by endpoint). Used to notify on friend requests etc.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Standalone (non-workout) heart-rate samples streamed from the StrengthLab
/// Android app via Health Connect — ambient/background readings that aren't
/// attached to a logged workout. Deduped per (user, timestamp) so the device
/// can re-send overlapping windows safely.
model AmbientHeartRateSample {
  id         String   @id @default(cuid())
  userId     String
  timestamp  DateTime
  bpm        Int
  sourceApp  String?  // originating Health Connect package, for provenance
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timestamp])
  @@index([userId, timestamp])
}

/// Pending friend handshake. A friendship is mutual: accepting a request
/// creates Follow edges in both directions, so all the follow-based queries
/// (feed, crew ranking, highlights, explore) keep working unchanged. Rows
/// are kept after accept/decline as a history + to gate re-requests.
model FriendRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  status     String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  from User @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  to   User @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

/// Follow-based crew challenge (replaces the old group-scoped Challenge).
/// Standings are computed on read from members' logged workouts in the
/// challenge window — nothing is pre-scored, so they're always accurate.
model CrewChallenge {
  id          String    @id @default(cuid())
  creatorId   String
  name        String
  type        String // VOLUME | SESSIONS | LIFT_RACE | STREAK
  exerciseId  String? // LIFT_RACE: the lift being raced
  targetValue Float? // LIFT_RACE: target weight (lb), optional
  targetReps  Int?
  startsAt    DateTime  @default(now())
  endsAt      DateTime? // null = open-ended
  createdAt   DateTime  @default(now())

  creator User                  @relation("CrewChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members CrewChallengeMember[]

  @@index([creatorId])
}

model CrewChallengeMember {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  joinedAt    DateTime @default(now())

  challenge CrewChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

/// Directed follow edge: `follower` follows `following`. One-way (Strava
/// style) — no accept step. Replaces the old crew/group membership model
/// as the basis for the Crew ranking and the home feed's "Crew" view.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

/// Per-user Google OAuth tokens for the Google Health API. The Health API
/// proxies data from the user's Fitbit device through Google, so this single
/// account also covers Fitbit reads — there's no separate Fitbit OAuth.
model HealthAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  provider        String   @default("google_health")
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  scope           String
  lastSyncedAt    DateTime?
  // Last-known resting HR, persisted during sync so the feed reads it instantly
  // instead of waiting on a live Google Health call.
  restingHr         Int?
  restingDelta      Int?
  restingSource     String?
  restingBaselineHr Int?
  restingHrAt       DateTime?
  // Recovery snapshot (HRV + RHR based; sleep added later). Computed on sync.
  recoveryScore     Int?      // 0–100
  recoveryBand      String?   // low | moderate | primed
  hrvMs             Float?    // latest night RMSSD
  hrvBaselineMs     Float?    // trailing baseline RMSSD
  recoveryAt        DateTime?
  // Last night's sleep: { asleepMin, inBedMin, deepMin, remMin, lightMin,
  // awakeMin, startUtc, endUtc, offsetSec }. nightKey = local date of wake.
  sleepSummary      Json?
  sleepNightKey     String?
  // Last ~30 nights for the weekly/monthly sleep chart:
  // [{ date:"YYYY-MM-DD", asleepMin, deepMin, remMin, lightMin, awakeMin }]
  sleepHistory      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Cached snapshot of Fitbit exercise sessions pulled from Google Health.
/// Upserted by (userId, externalId) on each refresh. `importedWorkoutId` is
/// set when the user clicks "Import as workout" so it disappears from the
/// detected list without needing a fresh API roundtrip.
model FitbitExerciseSession {
  id                String   @id @default(cuid())
  userId            String
  externalId        String
  startTime         DateTime
  endTime           DateTime
  displayName       String
  exerciseType      String?
  durationSec       Int      @default(0)
  calories          Int?
  steps             Int?
  avgHR             Int?
  activeZoneMin     Int?
  distanceMm        Int?
  importedWorkoutId String?
  fetchedAt         DateTime @default(now())

  @@unique([userId, externalId])
  @@index([userId, startTime])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  exerciseId   String?
  targetValue  Float
  targetReps   Int?
  unit         String?
  deadline     DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id])
}

model Workout {
  id           String   @id @default(cuid())
  userId       String
  title        String
  type         String
  split        String?
  date         DateTime @default(now())
  notes        String?
  feeling      String?
  isDeload     Boolean  @default(false)
  duration     Int?
  distance     Float?
  pace         String?
  avgHeartRate Int?
  maxHeartRate Int?
  rounds       Int?
  elevation    Int?
  calories     Int?
  steps        Int?
  activeZoneMin Int?
  rpe          Int?
  startedAt    DateTime?
  endedAt      DateTime?
  /// Coach-prescribed warmup payload: { items: [{ kind, name, durationSec?, reps?, instructions? }] }
  warmup       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises      WorkoutExercise[]
  comments       Comment[]
  reactions      Reaction[]
  posts          GroupPost[]
  heartRateSamples WorkoutHeartRateSample[]

  // Nearly every feed/crew/profile/challenge query filters by user and a date
  // window ordered by date — without this it's a full table scan.
  @@index([userId, date])
}

/// Heart-rate samples captured during a workout, pulled from Google Health.
/// One row per Fitbit reading; typical workout has 30-200 rows.
model WorkoutHeartRateSample {
  id        String   @id @default(cuid())
  workoutId String
  timestamp DateTime
  bpm       Int

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId, timestamp])
}

model Exercise {
  id          String  @id @default(cuid())
  name        String
  muscleGroup String?
  splits      String?
  isCustom    Boolean @default(false)
  ownerId     String?

  owner            User?              @relation("ExerciseOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]
  prs              PersonalRecord[]
  goals            Goal[]
  challenges       Challenge[]
}

model WorkoutExercise {
  id            String  @id @default(cuid())
  workoutId     String
  exerciseId    String
  order         Int
  notes         String?
  supersetGroup String?

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  sets     Set[]

  @@index([workoutId])
  @@index([exerciseId])
}

model Set {
  id                String    @id @default(cuid())
  workoutExerciseId String
  type              String
  setNumber         Int
  weight            Float?
  reps              Int?
  rir               Int?
  notes             String?
  loggedAt          DateTime?

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
}

model PersonalRecord {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  type       String
  value      Float
  reps       Int?
  date       DateTime @default(now())
  workoutId  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId, date])
  @@index([workoutId])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  members    GroupMember[]
  posts      GroupPost[]
  challenges Challenge[]
}

model GroupPost {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  text        String
  imageUrl    String?
  workoutId   String?
  cardType    String?
  cardData    Json?
  challengeId String?
  createdAt   DateTime @default(now())

  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout?       @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  challenge Challenge?     @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  comments  PostComment[]
  reactions PostReaction[]
}

model Challenge {
  id           String    @id @default(cuid())
  groupId      String
  creatorId    String
  type         String
  exerciseId   String?
  targetValue  Float
  targetReps   Int?
  deadline     DateTime?
  resolved     Boolean   @default(false)
  winnerId     String?
  createdAt    DateTime  @default(now())

  group        Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator      User                   @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  exercise     Exercise?              @relation(fields: [exerciseId], references: [id])
  participants ChallengeParticipant[]
  posts        GroupPost[]
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  joinedAt    DateTime  @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())

  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  workoutId String
  userId    String
  text      String
  createdAt DateTime @default(now())

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workoutId])
}

model Reaction {
  id        String @id @default(cuid())
  workoutId String
  userId    String
  type      String

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workoutId, userId, type])
}
