generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TrainerMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String
  image          String?
  bodyweight     Float?
  goals          String?
  preferredSplit String?
  bio            String?
  experienceLevel String?
  primaryFocus   String?
  trainingPhase  String?
  trainingDays   Int?
  injuries       String?
  coachPrompt    String?
  height         Float?
  bodyFat        Float?
  restingHR      Int?
  waist          Float?
  hips           Float?
  chest          Float?
  shoulders      Float?
  neck           Float?
  arm            Float?
  forearm        Float?
  thigh          Float?
  calf           Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workouts        Workout[]
  prs             PersonalRecord[]
  goalList        Goal[]
  groupMembers    GroupMember[]
  comments        Comment[]
  reactions       Reaction[]
  trainerMessages TrainerMessage[]
  groupPosts      GroupPost[]
  postComments    PostComment[]
  postReactions   PostReaction[]
  challenges      Challenge[]           @relation("ChallengeCreator")
  challengeJoins  ChallengeParticipant[]
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  exerciseId   String?
  targetValue  Float
  targetReps   Int?
  unit         String?
  deadline     DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id])
}

model Workout {
  id           String   @id @default(cuid())
  userId       String
  title        String
  type         String
  split        String?
  date         DateTime @default(now())
  notes        String?
  feeling      String?
  isDeload     Boolean  @default(false)
  duration     Int?
  distance     Float?
  pace         String?
  avgHeartRate Int?
  maxHeartRate Int?
  rounds       Int?
  elevation    Int?
  calories     Int?
  rpe          Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  comments  Comment[]
  reactions Reaction[]
  posts     GroupPost[]
}

model Exercise {
  id          String  @id @default(cuid())
  name        String  @unique
  muscleGroup String?
  splits      String?
  isCustom    Boolean @default(false)

  workoutExercises WorkoutExercise[]
  prs              PersonalRecord[]
  goals            Goal[]
  challenges       Challenge[]
}

model WorkoutExercise {
  id         String @id @default(cuid())
  workoutId  String
  exerciseId String
  order      Int
  notes      String?

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  sets     Set[]
}

model Set {
  id                String  @id @default(cuid())
  workoutExerciseId String
  type              String
  setNumber         Int
  weight            Float?
  reps              Int?
  rir               Int?
  notes             String?

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
}

model PersonalRecord {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  type       String
  value      Float
  reps       Int?
  date       DateTime @default(now())
  workoutId  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  members    GroupMember[]
  posts      GroupPost[]
  challenges Challenge[]
}

model GroupPost {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  text        String
  imageUrl    String?
  workoutId   String?
  cardType    String?
  cardData    Json?
  challengeId String?
  createdAt   DateTime @default(now())

  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout?       @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  challenge Challenge?     @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  comments  PostComment[]
  reactions PostReaction[]
}

model Challenge {
  id           String    @id @default(cuid())
  groupId      String
  creatorId    String
  type         String
  exerciseId   String?
  targetValue  Float
  targetReps   Int?
  deadline     DateTime?
  resolved     Boolean   @default(false)
  winnerId     String?
  createdAt    DateTime  @default(now())

  group        Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator      User                   @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  exercise     Exercise?              @relation(fields: [exerciseId], references: [id])
  participants ChallengeParticipant[]
  posts        GroupPost[]
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  joinedAt    DateTime  @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())

  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  workoutId String
  userId    String
  text      String
  createdAt DateTime @default(now())

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String @id @default(cuid())
  workoutId String
  userId    String
  type      String

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workoutId, userId, type])
}
